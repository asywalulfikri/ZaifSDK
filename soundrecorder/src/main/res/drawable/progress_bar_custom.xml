<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== BACKGROUND TRACK ===== -->

    <!-- Outer shadow / depth layer -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="0dp">
        <shape>
            <corners android:radius="50dp" />
            <solid android:color="#1A000000" />
        </shape>
    </item>

    <!-- Background base (dark groove) -->
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="50dp" />
            <gradient
                android:angle="270"
                android:centerColor="#2A2A2A"
                android:endColor="#1C1C1C"
                android:startColor="#333333"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#111111" />
        </shape>
    </item>

    <!-- ===== PROGRESS FILL ===== -->

    <item android:id="@android:id/progress">
        <clip android:clipOrientation="horizontal" android:gravity="left">
            <layer-list>

                <!-- Base gradient fill: bright gold → amber → deep orange -->
                <item>
                    <shape>
                        <corners android:radius="50dp" />
                        <gradient
                            android:angle="0"
                            android:centerColor="#FFB300"
                            android:centerX="0.5"
                            android:endColor="#FF6F00"
                            android:startColor="#FFD740"
                            android:type="linear" />
                    </shape>
                </item>

                <!-- Top gloss highlight (upper shine) -->
                <item
                    android:bottom="5dp"
                    android:left="2dp"
                    android:right="2dp"
                    android:top="1dp">
                    <shape>
                        <corners android:radius="50dp" />
                        <gradient
                            android:angle="270"
                            android:endColor="#00FFFFFF"
                            android:startColor="#50FFFFFF"
                            android:type="linear" />
                    </shape>
                </item>

                <!-- Bottom subtle reflection -->
                <item
                    android:bottom="1dp"
                    android:left="2dp"
                    android:right="2dp"
                    android:top="5dp">
                    <shape>
                        <corners android:radius="50dp" />
                        <gradient
                            android:angle="90"
                            android:endColor="#00FFFFFF"
                            android:startColor="#18FFFFFF"
                            android:type="linear" />
                    </shape>
                </item>

            </layer-list>
        </clip>
    </item>

</layer-list>