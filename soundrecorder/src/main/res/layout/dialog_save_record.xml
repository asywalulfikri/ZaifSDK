<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_wood"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="UNLOCK INSTRUMENT"
        android:textColor="#F5D76E"
        android:fontFamily="@font/campton_bold"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_30sdp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/campton_medium"
        android:textColor="@color/black_de"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/bg_btn_dark"
            android:text="CANCEL"
            android:fontFamily="@font/campton_bold"
            android:textColor="#AAAAAA" />

        <TextView
            android:id="@+id/btnWatch"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="@font/campton_bold"
            android:background="@drawable/bg_btn_wood"
            android:text="WATCH AD"
            android:textColor="#1F1612"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>