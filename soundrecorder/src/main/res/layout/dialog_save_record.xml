<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_wood"
    android:orientation="vertical"
    android:padding="@dimen/_16sdp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="UNLOCK INSTRUMENT"
        android:textColor="#F5D76E"
        android:fontFamily="@font/campton_bold"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_30sdp"
        android:layout_marginTop="@dimen/_8sdp"
        android:gravity="center"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/campton_medium"
        android:textColor="@color/black_de"
        android:textSize="@dimen/_11ssp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_14sdp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="@dimen/_38sdp"
            android:layout_marginEnd="@dimen/_6sdp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/bg_btn_dark"
            android:text="CANCEL"
            android:fontFamily="@font/campton_bold"
            android:textColor="#AAAAAA"
            android:textSize="@dimen/_11ssp" />

        <TextView
            android:id="@+id/btnWatch"
            android:layout_width="0dp"
            android:layout_height="@dimen/_38sdp"
            android:layout_marginStart="@dimen/_6sdp"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="@font/campton_bold"
            android:background="@drawable/bg_btn_wood"
            android:text="WATCH AD"
            android:textColor="#1F1612"
            android:textSize="@dimen/_11ssp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>