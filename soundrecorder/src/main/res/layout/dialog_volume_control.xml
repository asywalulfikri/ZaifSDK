<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="@dimen/_8sdp"
    app:cardBackgroundColor="@color/amber_50"
    android:layout_margin="@dimen/_12sdp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <!-- Judul -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ooredoo"
            android:text="@string/volume"
            android:textAlignment="center"
            android:textColor="@color/black_de"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/_12sdp" />

        <!-- Label Music -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ooredoo"
            android:text="@string/song_volume"
            android:textColor="@color/black_de"
            android:textSize="@dimen/_13ssp"
            android:alpha="0.7" />

        <!-- Row SeekBar Music -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/_22sdp"
                android:layout_height="@dimen/_22sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                app:srcCompat="@drawable/volume_loud_svgrepo_com"
                app:tint="@color/black_de" />

            <!--
                SmoothSeekBar: hanya butuh id, layout_width, layout_height.
                Hapus android:max, android:progressDrawable, android:thumb, android:splitTrack
                karena semua itu dikontrol langsung dari Kotlin (bukan SeekBar bawaan).
            -->
            <sound.recorder.widget.music.SmoothSeekBar
                android:id="@+id/seekBarMusic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A000000"
            android:layout_marginTop="@dimen/_16sdp"
            android:layout_marginBottom="@dimen/_16sdp" />

        <!-- Label Audio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/ooredoo"
                android:text="@string/volume"
                android:textColor="@color/black_de"
                android:textSize="@dimen/_13ssp"
                android:alpha="0.7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:fontFamily="@font/ooredoo"
                android:text="@string/app_name"
                android:textColor="@color/black_de"
                android:textSize="@dimen/_11ssp"
                android:textStyle="italic"
                android:alpha="0.5" />

        </LinearLayout>

        <!-- Row SeekBar Audio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/_22sdp"
                android:layout_height="@dimen/_22sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                app:srcCompat="@drawable/volume_loud_svgrepo_com"
                app:tint="@color/black_de" />

            <sound.recorder.widget.music.SmoothSeekBar
                android:id="@+id/seekBarAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>