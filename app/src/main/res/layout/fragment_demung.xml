<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:clickable="true"
    android:layout_height="match_parent"
    android:id="@+id/layoutBackground"
    android:background="@color/blue_700"
    android:focusable="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/rr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_50sdp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/_8sdp"
        android:paddingEnd="@dimen/_8sdp">

        <ImageView
            android:id="@+id/tvSpeedMin"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:background="@drawable/minus"
            android:contentDescription="@string/app_name"
            android:padding="@dimen/_6sdp"
            android:visibility="gone"
            app:tint="@color/white" />

        <sound.recorder.widget.util.SpeedMarquee
            android:id="@+id/tvRunningText"
            android:layout_width="0dp"
            android:layout_height="@dimen/_24sdp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/_4sdp"
            android:layout_marginEnd="@dimen/_4sdp"
            android:background="@drawable/bg_marquee_curved"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/_10sdp"
            android:paddingEnd="@dimen/_10sdp"
            android:fontFamily="@font/rimouski"
            android:singleLine="true"
            android:text="@string/text_choose_not"
            android:textColor="@color/white"
            android:textSize="@dimen/_12ssp"
            app:marquee_speed="100.0" />

        <ImageView
            android:id="@+id/tvClear"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:layout_marginEnd="@dimen/_4sdp"
            android:background="@drawable/button_black"
            android:padding="@dimen/_6sdp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_delete_white"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/tvSpeedPlus"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:background="@drawable/plus"
            android:padding="@dimen/_6sdp"
            android:visibility="gone"
            app:tint="@color/white" />

    </LinearLayout>


    <RelativeLayout
        android:layout_below="@+id/rr"
        android:layout_toEndOf="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <recording.host.DemungView
            android:id="@+id/instrumentView"
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </RelativeLayout>

    <LinearLayout
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/rr"
        android:id="@+id/llCreate"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_gravity="bottom"
            android:id="@+id/ivStop"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:padding="15dp"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:background="@drawable/piring"
            android:backgroundTint="@color/yellow_900"
            app:srcCompat="@drawable/ic_pause"
            android:textColor="@android:color/white"
            android:contentDescription="@string/app_name" />

    </LinearLayout>

    <sound.recorder.widget.recording.InstrumentControlPanel
        android:id="@+id/controlPanel"
        android:layout_below="@+id/rr"
        android:layout_alignParentBottom="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical" />


</RelativeLayout>
