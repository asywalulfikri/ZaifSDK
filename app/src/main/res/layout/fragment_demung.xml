<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:clickable="true"
    android:layout_height="match_parent"
    android:id="@+id/layoutBackground"
    android:background="@color/blue_700"
    android:focusable="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/rr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_50sdp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/_8sdp"
        android:paddingEnd="@dimen/_8sdp">

        <sound.recorder.widget.util.MarqueeControlView
            android:id="@+id/marqueeControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>


    <RelativeLayout
        android:layout_below="@+id/rr"
        android:layout_toEndOf="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <recording.host.DemungView
            android:id="@+id/instrumentView"
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </RelativeLayout>

    <LinearLayout
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/rr"
        android:id="@+id/llCreate"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_gravity="bottom"
            android:id="@+id/ivStop"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:padding="15dp"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:background="@drawable/piring"
            android:backgroundTint="@color/yellow_900"
            app:srcCompat="@drawable/ic_pause"
            android:textColor="@android:color/white"
            android:contentDescription="@string/app_name" />

    </LinearLayout>

    <!-- Button: Not from User -->
    <TextView
        android:id="@+id/btnNotFromUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rr"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="6dp"
        android:text="♪ Not User"
        android:textColor="#FFB347"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/circle_line_champ"
        android:clickable="true"
        android:focusable="true" />

    <!-- Learn Mode Indicator -->
    <LinearLayout
        android:id="@+id/learnIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvLearnStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1/10"
            android:textColor="#80DCFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/btnStopLearn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕ Stop"
            android:textColor="#CF6679"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" /></LinearLayout>

    <LinearLayout
        android:layout_alignParentBottom="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btnTutorial"
            android:layout_marginStart="@dimen/_4sdp"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_28sdp"
            android:background="@drawable/bg_btn_tutorial_learn"
            android:gravity="center"
            android:backgroundTint="@color/red_900"
            android:layout_marginTop="@dimen/_5sdp"
            android:text="@string/tutorial"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/_7ssp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <sound.recorder.widget.recording.InstrumentControlPanel
            android:id="@+id/controlPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>


    <TextView
        android:id="@+id/tvTimer"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:textColor="@color/black_de"
        android:textSize="@dimen/_16ssp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>


</RelativeLayout>
